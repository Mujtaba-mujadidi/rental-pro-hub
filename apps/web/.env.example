# Copy to .env.local — https://supabase.com/dashboard/project/_/settings/api
#
# Auth emails (password reset, invites, magic links, confirmations) are sent by Supabase Auth.
# The built-in mailer uses a strict project-wide hourly cap (often 2/hour); invites + resets share it.
# To raise limits: Supabase Dashboard → Project Settings → Authentication → SMTP Settings (custom SMTP).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Public site origin (no trailing slash). Used for auth callbacks and redirects.
# Example: http://localhost:3000  or  https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role key — server-only. Required for super-admin driver list and driver preview (service role).
# Supabase Dashboard → Settings → API → service_role (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: this email always routes to /super-admin after login (must match profiles.role or use SQL).
SUPER_ADMIN_EMAIL=admin@example.com

# DocuSeal (optional). Without DOCUSEAL_API_KEY, new contracts use legacy bootstrap signing unless overridden.
#
# Cloud API (default if DOCUSEAL_BASE_URL unset):
# DOCUSEAL_BASE_URL=https://api.docuseal.com
#
# Self-hosted (avoid cloud signature limits): deploy per https://www.docuseal.com/install — Docker example:
#   curl -O https://raw.githubusercontent.com/docusealco/docuseal/master/docker-compose.yml
#   sudo HOST=sign.yourcompany.com docker compose up
# Set DOCUSEAL_BASE_URL to the HTTPS origin where POST /submissions works (this app uses `${DOCUSEAL_BASE_URL}/submissions`
# and header X-Auth-Token). If your build uses an API path prefix, include it in the URL.
# Create API key + template in self-hosted admin; set DOCUSEAL_CONTRACT_TEMPLATE_ID to that template’s id.
# Webhooks: URL https://<your-next-app>/api/webhooks/docuseal — set DOCUSEAL_WEBHOOK_SECRET (and header name if custom).
# DocuSeal AGPLv3 — review license for your use case.
#
# DOCUSEAL_BASE_URL=https://sign.yourcompany.com
# DOCUSEAL_API_KEY=
# DOCUSEAL_CONTRACT_TEMPLATE_ID=123
# DOCUSEAL_WEBHOOK_SECRET=
# DOCUSEAL_WEBHOOK_HEADER_NAME=X-Webhook-Secret
# RENTAL_CONTRACT_LEGACY_BOOTSTRAP_SIGNED=true
