# Copy to .env.local — https://supabase.com/dashboard/project/_/settings/api
#
# Auth emails (password reset, invites, magic links, confirmations) are sent by Supabase Auth.
# The built-in mailer uses a strict project-wide hourly cap (often 2/hour); invites + resets share it.
# To raise limits: Supabase Dashboard → Project Settings → Authentication → SMTP Settings (custom SMTP).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Public site origin (no trailing slash). Used for auth callbacks and redirects.
# Example: http://localhost:3000  or  https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service role key — server-only. Required for super-admin driver list and driver preview (service role).
# Supabase Dashboard → Settings → API → service_role (never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: this email always routes to /super-admin after login (must match profiles.role or use SQL).
SUPER_ADMIN_EMAIL=admin@example.com

# Optional: protect scheduled jobs (e.g. Vercel Cron) that call GET /api/cron/company-offboarding-expiry
# with header Authorization: Bearer <CRON_SECRET>. Flips offboarding companies to access_blocked after offboarding_ends_at.
# CRON_SECRET=

# Native e-sign (see docs/esign.md). Prefer Resend on Railway Hobby (SMTP ports blocked).
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="RMS <onboarding@resend.dev>"
#
# SMTP works locally and on Railway Pro+. If unset and no Resend key, OTP/link emails log to console in development.
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM="RMS <noreply@example.com>"
#
# When true, new companies skip e-sign (contract marked active immediately).
# RENTAL_CONTRACT_LEGACY_BOOTSTRAP_SIGNED=false
